{
  "name": "react_test",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:backend\" \"npm:dev:web\" \"npm:dev:electron\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "format": "prettier --write .",
    "dev:backend": "node electron/backend-runner.cjs",
    "dev:web": "vite --host 127.0.0.1 --port 5174 --strictPort",
    "dev:electron": "wait-on tcp:127.0.0.1:5174 && node electron/dev-runner.cjs",
    "dev:hw": "cross-env NNOVEL_FORCE_HARDWARE=1 NNOVEL_ANGLE_BACKEND=d3d11 concurrently -k \"npm:dev:backend\" \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:hw:diag": "cross-env NNOVEL_FORCE_HARDWARE=1 NNOVEL_ANGLE_BACKEND=d3d11 NNOVEL_GPU_PROFILE=compat NNOVEL_GPU_DIAG=1 concurrently -k \"npm:dev:backend\" \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:hw:compat": "cross-env NNOVEL_FORCE_HARDWARE=1 NNOVEL_ANGLE_BACKEND=d3d11 NNOVEL_GPU_PROFILE=compat concurrently -k \"npm:dev:backend\" \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:hw:strict": "cross-env NNOVEL_FORCE_HARDWARE=1 NNOVEL_STRICT_HARDWARE=1 NNOVEL_ANGLE_BACKEND=d3d11 concurrently -k \"npm:dev:backend\" \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:gpu:strict": "cross-env NNOVEL_FORCE_HARDWARE=1 NNOVEL_STRICT_HARDWARE=1 NNOVEL_NO_SANDBOX=1 NNOVEL_ANGLE_BACKEND=d3d11 NNOVEL_GPU_DIAG=1 concurrently -k \"npm:dev:backend\" \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:hw:gl": "cross-env NNOVEL_FORCE_HARDWARE=1 NNOVEL_ANGLE_BACKEND=gl concurrently -k \"npm:dev:backend\" \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:hw:d3d11on12": "cross-env NNOVEL_FORCE_HARDWARE=1 NNOVEL_ANGLE_BACKEND=d3d11on12 concurrently -k \"npm:dev:backend\" \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:gpu:nosandbox": "cross-env NNOVEL_FORCE_HARDWARE=1 NNOVEL_NO_SANDBOX=1 NNOVEL_GPU_DIAG=1 concurrently -k \"npm:dev:backend\" \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:gpu:desktop-gl": "cross-env NNOVEL_FORCE_HARDWARE=1 NNOVEL_ANGLE_BACKEND=gl NNOVEL_NO_SANDBOX=1 NNOVEL_GPU_DIAG=1 concurrently -k \"npm:dev:backend\" \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:gpu:verbose": "cross-env NNOVEL_FORCE_HARDWARE=1 NNOVEL_GPU_DIAG=1 NNOVEL_GPU_VERBOSE=1 concurrently -k \"npm:dev:backend\" \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:browser": "vite --host 127.0.0.1 --port 5174 --strictPort"
  },
  "dependencies": {
    "balanced-match": "^4.0.2",
    "liquid-glass-react": "file:../../git clone/liquid-glass-react",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.4.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "autoprefixer": "^10.4.22",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "main": "electron/main.cjs"
}
